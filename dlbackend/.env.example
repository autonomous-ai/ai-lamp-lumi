DL_API_KEY=changeme
DL_BACKEND_URL=http://localhost:8001

# Model selection: videomae | uniformerv2 | x3d
ACTION_RECOGNITION_MODEL=x3d

# Optional: path to a custom checkpoint file
# ACTION_RECOGNITION_CKPT_PATH=/path/to/model.onnx

# Per-model overrides (nested via __ delimiter)
# VIDEOMAE__CONFIDENCE_THRESHOLD=0.3
# VIDEOMAE__MAX_FRAMES=8
# VIDEOMAE__FRAME_INTERVAL=1.0
# VIDEOMAE__W=224
# VIDEOMAE__H=224

# UNIFORMERV2__CONFIDENCE_THRESHOLD=0.3
# UNIFORMERV2__MAX_FRAMES=8
# UNIFORMERV2__FRAME_INTERVAL=1.0
# UNIFORMERV2__W=224
# UNIFORMERV2__H=224

# X3D__CONFIDENCE_THRESHOLD=0.3
# X3D__MAX_FRAMES=16
# X3D__FRAME_INTERVAL=1.0
# X3D__W=256
# X3D__H=256
