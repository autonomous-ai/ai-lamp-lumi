DL_API_KEY=changeme
DL_BACKEND_URL=http://localhost:8001

# --- Action recognition ---
# Model selection: videomae | uniformerv2 | x3d
ACTION_RECOGNITION_MODEL=x3d
# ACTION_RECOGNITION_CKPT_PATH=/path/to/model.onnx

# --- Emotion recognition (EmoNet: 8 emotions + valence/arousal) ---
# EMOTION_RECOGNITION_CKPT_PATH=/path/to/emonet_8.onnx

# --- Per-model overrides (nested via __ delimiter) ---

# VIDEOMAE__CONFIDENCE_THRESHOLD=0.3
# VIDEOMAE__MAX_FRAMES=16
# VIDEOMAE__FRAME_INTERVAL=1.0
# VIDEOMAE__W=224
# VIDEOMAE__H=224

# UNIFORMERV2__CONFIDENCE_THRESHOLD=0.3
# UNIFORMERV2__MAX_FRAMES=8
# UNIFORMERV2__FRAME_INTERVAL=1.0
# UNIFORMERV2__W=224
# UNIFORMERV2__H=224

# X3D__CONFIDENCE_THRESHOLD=0.3
# X3D__MAX_FRAMES=16
# X3D__FRAME_INTERVAL=1.0
# X3D__W=256
# X3D__H=256

# EMOTION__CONFIDENCE_THRESHOLD=0.5
# EMOTION__FRAME_INTERVAL=1.0


# --- Audio recognition ---
# Options: resnet34 | ecapa-tdnn1024 | campplus
AUDIO_RECOGNIZER_ENGINE=resnet34